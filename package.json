{
  "name": "genkit-template",
  "private": true,
  "version": "1.0.0",
  "description": "Production-ready Genkit AI orchestration template with Firebase Cloud Functions",
  "main": "dist/index.js",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "genkit start -- tsx --watch src/index.ts",
    "build": "tsc",
    "serve": "tsx src/index.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky"
  },
  "dependencies": {
    "@genkit-ai/firebase": "^1.0.4",
    "@genkit-ai/google-genai": "^1.0.4",
    "@genkit-ai/vertexai": "^1.0.4",
    "dotenv": "^16.4.0",
    "firebase-admin": "^13.0.0",
    "firebase-functions": "^6.3.0",
    "genkit": "^1.0.4",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.8.0",
    "@commitlint/config-conventional": "^19.8.0",
    "@eslint/js": "^9.0.0",
    "@types/node": "^22.0.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^10.0.0",
    "genkit-cli": "^1.0.4",
    "husky": "^9.1.0",
    "lint-staged": "^16.0.0",
    "prettier": "^3.5.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^3.2.0"
  },
  "lint-staged": {
    "*.{ts,js}": ["eslint --fix", "prettier --write"],
    "*.{json,md}": ["prettier --write"]
  }
}
